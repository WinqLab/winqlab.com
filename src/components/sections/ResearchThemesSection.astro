---
interface Props {
  items: string[];
}

const { items } = Astro.props;
---

<section class="section-block">
  <div class="section-heading">
    <p class="section-kicker">Themes</p>
    <h2>当前关注的研究方向</h2>
  </div>
  <div class="themes-grid">
    {
      items.map((item) => (
        <article class="theme-card">
          <p>{item}</p>
        </article>
      ))
    }
  </div>
</section>

<style>
  .section-block {
    padding: 36px 0;
  }

  .section-heading {
    margin-bottom: 24px;
  }

  .section-kicker {
    margin: 0 0 8px;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.74rem;
  }

  h2 {
    margin: 0;
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    line-height: 1.1;
  }

  .themes-grid {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }

  .theme-card {
    min-height: 180px;
    display: flex;
    align-items: flex-end;
    padding: 24px;
    border-radius: 24px;
    border: 1px solid var(--border-subtle);
    background:
      linear-gradient(180deg, rgba(61, 210, 255, 0.03), rgba(61, 210, 255, 0)),
      var(--color-panel-strong);
  }

  .theme-card p {
    margin: 0;
    font-size: 1.04rem;
    line-height: 1.6;
  }
</style>
