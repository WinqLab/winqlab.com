---
interface Action {
  label: string;
  href: string;
}

interface Props {
  title: string;
  description: string;
  supporting: string;
  actions: Action[];
}

const surfaceRows = [
  { label: "系统路径", value: "研究假设 -> 系统验证 -> 实盘交易" },
  { label: "核心原则", value: "可迭代、可审查、可扩展" },
  { label: "当前焦点", value: "方法框架、执行效率、系统工程" },
];

const { title, description, supporting, actions } = Astro.props;

const titleLines = (() => {
  const marker = "，再到";
  if (!title.includes(marker)) return [title];

  const [lead, tail] = title.split(marker);
  return [lead, `再到${tail}`];
})();
---

<section class="hero-section">
  <div class="hero-copy">
    <p class="hero-kicker">研究与交易系统</p>
    <h1>
      {titleLines.map((line) => (
        <span>{line}</span>
      ))}
    </h1>
    <p class="hero-description">{description}</p>
    <p class="hero-supporting">{supporting}</p>
    <div class="hero-actions">
      {
        actions.map((action, index) => (
          <a
            href={action.href}
            class:list={[
              "hero-action",
              index === 0 ? "hero-action--primary" : "hero-action--secondary",
            ]}
          >
            {action.label}
          </a>
        ))
      }
    </div>
  </div>
  <aside class="hero-surface">
    <article class="hero-surface__card">
      <span class="hero-surface__eyebrow">系统概览</span>
      <p class="hero-surface__title">研究到交易</p>
      <p class="hero-surface__summary">把研究、验证与执行放进同一套长期演进的系统结构。</p>
      <div class="hero-surface__rows">
        {
          surfaceRows.map((row) => (
            <div class="hero-surface__row">
              <span class="hero-surface__row-label">{row.label}</span>
              <p class="hero-surface__row-value">{row.value}</p>
            </div>
          ))
        }
      </div>
    </article>
  </aside>
</section>

<style>
  .hero-section {
    padding: clamp(44px, 5.2vw, 76px) 0 68px;
    display: grid;
    gap: 48px;
    align-items: start;
  }

  .hero-copy {
    max-width: 44rem;
  }

  .hero-kicker {
    margin: 0 0 20px;
    color: var(--color-accent);
    letter-spacing: 0.16em;
    font-size: 0.76rem;
  }

  h1 {
    display: grid;
    gap: 0.18em;
    margin: 0;
    width: fit-content;
    font-size: clamp(2.8rem, 4.9vw, 4.05rem);
    line-height: 0.98;
    letter-spacing: -0.06em;
  }

  h1 span {
    display: block;
    white-space: nowrap;
  }

  .hero-description,
  .hero-supporting {
    max-width: 31rem;
    font-size: 1rem;
    line-height: 1.95;
  }

  .hero-description {
    margin: 30px 0 0;
    color: var(--color-text);
  }

  .hero-supporting {
    margin: 16px 0 0;
    color: var(--color-muted);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-top: 34px;
  }

  .hero-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 22px;
    border-radius: 999px;
    border: 1px solid var(--border-subtle);
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background-color 180ms ease;
  }

  .hero-action:hover,
  .hero-action:focus-visible {
    transform: translateY(-1px);
  }

  .hero-action--primary {
    background: linear-gradient(135deg, var(--color-accent-soft), rgba(61, 210, 255, 0.08));
    border-color: rgba(61, 210, 255, 0.38);
  }

  .hero-action--secondary {
    color: var(--color-muted);
  }

  .hero-surface {
    position: relative;
    width: 100%;
    max-width: 344px;
    margin-left: auto;
    margin-top: 8px;
  }

  .hero-surface::before {
    content: "";
    position: absolute;
    inset: auto auto 12% -10%;
    width: 160px;
    height: 160px;
    border-radius: 999px;
    background: rgba(61, 210, 255, 0.12);
    filter: blur(72px);
    pointer-events: none;
  }

  .hero-surface__card {
    position: relative;
    z-index: 1;
    padding: 26px 24px;
    border-radius: 30px;
    border: 1px solid rgba(148, 163, 184, 0.16);
    background:
      linear-gradient(180deg, rgba(61, 210, 255, 0.04), rgba(61, 210, 255, 0)),
      linear-gradient(180deg, rgba(14, 24, 35, 0.9), rgba(8, 16, 25, 0.86));
    box-shadow: var(--shadow-panel);
    backdrop-filter: blur(14px);
  }

  .hero-surface__eyebrow,
  .hero-surface__row-label {
    display: inline-flex;
    color: var(--color-accent);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
  }

  .hero-surface__title,
  .hero-surface__summary,
  .hero-surface__row-value {
    margin: 0;
  }

  .hero-surface__title {
    margin-top: 18px;
    font-size: 1.48rem;
    line-height: 1.16;
  }

  .hero-surface__summary {
    margin-top: 12px;
    color: var(--color-muted);
    font-size: 0.95rem;
    line-height: 1.76;
  }

  .hero-surface__rows {
    display: grid;
    gap: 16px;
    margin-top: 24px;
    padding-top: 22px;
    border-top: 1px solid rgba(148, 163, 184, 0.12);
  }

  .hero-surface__row {
    display: grid;
    gap: 7px;
  }

  .hero-surface__row-label {
    color: var(--color-muted);
  }

  .hero-surface__row-value {
    font-size: 0.92rem;
    line-height: 1.68;
  }

  @media (min-width: 960px) {
    .hero-section {
      grid-template-columns: minmax(0, 1.34fr) minmax(280px, 0.66fr);
    }
  }

  @media (max-width: 959px) {
    .hero-section {
      gap: 28px;
      padding-top: 52px;
      padding-bottom: 56px;
    }

    .hero-copy {
      max-width: 100%;
    }

    .hero-surface {
      max-width: 100%;
      margin-top: 8px;
    }
  }

  @media (max-width: 640px) {
    h1 {
      width: auto;
      font-size: clamp(2.55rem, 12vw, 3.45rem);
      line-height: 1.04;
    }

    h1 span {
      white-space: normal;
    }

    .hero-description,
    .hero-supporting {
      max-width: 100%;
      font-size: 0.98rem;
    }

    .hero-surface__card {
      padding: 24px 22px;
    }

    .hero-actions {
      gap: 12px;
    }

    .hero-action {
      width: 100%;
    }
  }
</style>
