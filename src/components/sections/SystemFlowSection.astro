---
interface Props {
  items: string[];
}

const { items } = Astro.props;
---

<section class="section-block" id="system-flow">
  <div class="section-heading">
    <p class="section-kicker">System Flow</p>
    <h2>把研究组织成一条连续运转的系统链路</h2>
    <p class="section-description">
      从市场数据到策略实验，再到执行与监控，WinqLab 将量化研究视为一条连续运转的系统链路。
    </p>
  </div>
  <div class="system-console">
    <div class="system-console__header">
      <span class="system-console__title">Research Path Console</span>
      <div class="system-console__modes">
        <span>Static Export</span>
        <span>System View</span>
      </div>
    </div>
    <div class="system-flow">
      {
        items.map((item, index) => (
          <>
            <article class="system-node">
              <span class="system-node__index">{String(index + 1).padStart(2, "0")}</span>
              <p class="system-node__label">{item}</p>
            </article>
            {index < items.length - 1 && <span class="system-flow__arrow">→</span>}
          </>
        ))
      }
    </div>
  </div>
</section>

<style>
  .section-block {
    padding: 36px 0;
  }

  .section-heading {
    margin-bottom: 24px;
  }

  .section-kicker {
    margin: 0 0 8px;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.74rem;
  }

  h2 {
    margin: 0;
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    line-height: 1.1;
  }

  .section-description {
    margin: 16px 0 0;
    max-width: 56rem;
    color: var(--color-muted);
    line-height: 1.8;
  }

  .system-flow {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 14px;
  }

  .system-console {
    padding: 18px;
    border-radius: 28px;
    border: 1px solid var(--border-subtle);
    background:
      linear-gradient(180deg, rgba(61, 210, 255, 0.05), rgba(61, 210, 255, 0)),
      rgba(10, 18, 27, 0.82);
    box-shadow: var(--shadow-glow);
  }

  .system-console__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    padding-bottom: 16px;
    margin-bottom: 18px;
    border-bottom: 1px solid rgba(148, 163, 184, 0.12);
  }

  .system-console__title {
    color: var(--color-accent);
    font-size: 0.76rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .system-console__modes {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .system-console__modes span {
    display: inline-flex;
    align-items: center;
    min-height: 32px;
    padding: 0 12px;
    border-radius: 999px;
    border: 1px solid rgba(148, 163, 184, 0.16);
    color: var(--color-muted);
    font-size: 0.74rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .system-node {
    min-width: 150px;
    flex: 1 1 150px;
    padding: 20px;
    border-radius: 20px;
    border: 1px solid rgba(148, 163, 184, 0.14);
    background: rgba(255, 255, 255, 0.02);
  }

  .system-node__index,
  .system-node__label {
    margin: 0;
  }

  .system-node__index {
    display: inline-block;
    color: var(--color-accent);
    font-size: 0.74rem;
    letter-spacing: 0.14em;
    margin-bottom: 14px;
  }

  .system-node__label {
    line-height: 1.55;
  }

  .system-flow__arrow {
    color: var(--color-accent);
  }
</style>
