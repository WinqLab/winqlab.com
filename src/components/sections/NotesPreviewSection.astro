---
interface Props {
  title: string;
  description: string;
  tracks: string[];
}

const { title, description, tracks } = Astro.props;
---

<section class="section-block">
  <div class="notes-layout">
    <div class="section-heading notes-lead">
      <p class="section-kicker">研究札记</p>
      <h2>{title}</h2>
      <p class="section-description">{description}</p>
    </div>
    <div class="notes-grid">
      {
        tracks.map((track, index) => (
          <article class="note-card">
            <span class="note-card__index">{String(index + 1).padStart(2, "0")}</span>
            <p class="note-card__label">{track}</p>
            <p class="note-card__hint">内容会围绕方法、结构与实验持续整理。</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .section-block {
    padding: 36px 0;
  }

  .notes-layout {
    display: grid;
    gap: 20px;
  }

  .section-kicker {
    margin: 0 0 8px;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.74rem;
  }

  h2 {
    margin: 0;
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    line-height: 1.1;
  }

  .section-description {
    margin: 16px 0 0;
    max-width: 56rem;
    color: var(--color-muted);
    line-height: 1.8;
  }

  .notes-grid {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }

  .note-card {
    min-height: 180px;
    padding: 24px;
    border-radius: 24px;
    border: 1px solid var(--border-subtle);
    background:
      linear-gradient(180deg, rgba(61, 210, 255, 0.05), rgba(61, 210, 255, 0)),
      rgba(10, 18, 27, 0.6);
  }

  .note-card__index,
  .note-card__label,
  .note-card__hint {
    margin: 0;
  }

  .note-card__index {
    display: inline-flex;
    margin-bottom: 16px;
    color: var(--color-accent);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .note-card__label {
    font-size: 1.05rem;
    font-weight: 600;
  }

  .note-card__hint {
    margin-top: 12px;
    color: var(--color-muted);
    line-height: 1.75;
  }

  @media (min-width: 960px) {
    .notes-layout {
      grid-template-columns: minmax(260px, 0.44fr) minmax(0, 1.56fr);
      align-items: start;
    }

    .notes-lead {
      padding-top: 6px;
    }
  }
</style>
