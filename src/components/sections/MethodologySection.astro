---
interface Props {
  title: string;
  description: string;
  steps: string[];
}

const stepNotes: Record<string, string> = {
  问题定义: "界定研究对象、约束与要回答的核心问题。",
  假设提出: "把观察转成可验证的研究假设与实验方向。",
  数据构建: "围绕假设组织输入、清洗逻辑与特征表达。",
  实验验证: "在统一框架中检验假设是否成立，并保留实验上下文。",
  结果审查: "复核结果、识别偏差来源并判断是否可继续推进。",
  持续迭代: "将反馈重新注入研究流程，形成长期演进的闭环。",
};

const stepTags: Record<string, string> = {
  问题定义: "界定",
  假设提出: "假设",
  数据构建: "数据",
  实验验证: "验证",
  结果审查: "审查",
  持续迭代: "迭代",
};

const { title, description, steps } = Astro.props;

const titleLines = (() => {
  const marker = "，而是";
  if (!title.includes(marker)) return [title];

  const [lead, tail] = title.split(marker);
  return [lead, `而是${tail}`];
})();
---

<section class="section-block methodology-section" id="methodology">
  <div class="methodology-layout">
    <div class="section-heading methodology-rail">
      <div class="methodology-rail__copy">
        <p class="section-kicker">研究方法</p>
        <h2>
          {titleLines.map((line) => (
            <span>{line}</span>
          ))}
        </h2>
        <p class="section-description">{description}</p>
      </div>
      <div class="methodology-rail__legend">
        <span>研究闭环</span>
        <span>结构化审查</span>
        <span>系统优先</span>
      </div>
    </div>
    <ol class="methodology-grid">
      {
        steps.map((step, index) => (
          <li class="methodology-step">
            <div class="methodology-step__meta">
              <span class="methodology-step__index">{String(index + 1).padStart(2, "0")}</span>
              <span class="methodology-step__tag">{stepTags[step]}</span>
            </div>
            <span class="methodology-step__label">{step}</span>
            <p class="methodology-step__note">{stepNotes[step]}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .section-block {
    padding: 36px 0;
  }

  .methodology-layout {
    display: grid;
    gap: 22px;
  }

  .methodology-rail {
    display: grid;
    gap: 26px;
    padding: 24px;
    border: 1px solid var(--border-subtle);
    border-radius: 28px;
    background:
      linear-gradient(180deg, rgba(61, 210, 255, 0.04), rgba(61, 210, 255, 0)),
      var(--color-panel-soft);
    box-shadow: var(--shadow-glow);
  }

  .methodology-rail__copy {
    display: grid;
    gap: 18px;
    align-content: start;
  }

  .section-kicker {
    margin: 0 0 8px;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.74rem;
  }

  h2 {
    display: grid;
    gap: 0.2em;
    margin: 0;
    max-width: 11ch;
    font-size: clamp(1.68rem, 2.12vw, 2.18rem);
    line-height: 1.1;
    letter-spacing: -0.035em;
  }

  h2 span {
    display: block;
  }

  .section-description {
    margin: 0;
    max-width: 30rem;
    color: var(--color-muted);
    line-height: 1.8;
  }

  .methodology-rail__legend {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: auto;
  }

  .methodology-rail__legend span {
    display: inline-flex;
    align-items: center;
    min-height: 34px;
    padding: 0 12px;
    border-radius: 999px;
    border: 1px solid rgba(148, 163, 184, 0.16);
    color: var(--color-muted);
    font-size: 0.74rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .methodology-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }

  .methodology-step {
    display: grid;
    gap: 14px;
    min-height: 186px;
    height: 100%;
    padding: 22px;
    border-radius: 24px;
    background: linear-gradient(180deg, rgba(14, 24, 35, 0.92), rgba(8, 16, 25, 0.86));
    border: 1px solid var(--border-subtle);
  }

  .methodology-step__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .methodology-step__index {
    color: var(--color-accent);
    font-size: 0.84rem;
    letter-spacing: 0.14em;
  }

  .methodology-step__tag {
    color: var(--color-muted);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .methodology-step__label {
    font-size: 1.1rem;
    line-height: 1.45;
  }

  .methodology-step__note {
    margin: 0;
    color: var(--color-muted);
    line-height: 1.75;
  }

  @media (min-width: 980px) {
    .methodology-layout {
      grid-template-columns: minmax(408px, 0.92fr) minmax(0, 1.08fr);
      align-items: stretch;
    }

    .methodology-rail {
      min-height: 100%;
      align-content: space-between;
      position: sticky;
      top: 104px;
    }

    .methodology-grid {
      align-content: stretch;
    }

    h2 span {
      white-space: nowrap;
    }
  }

  @media (min-width: 1180px) {
    .methodology-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 979px) {
    h2 {
      max-width: none;
      line-height: 1.12;
    }
  }

  @media (max-width: 640px) {
    h2 span {
      white-space: normal;
    }
  }
</style>
