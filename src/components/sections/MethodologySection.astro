---
interface Props {
  title: string;
  description: string;
  steps: string[];
}

const { title, description, steps } = Astro.props;
---

<section class="section-block methodology-section" id="methodology">
  <div class="section-heading">
    <p class="section-kicker">Methodology</p>
    <h2>{title}</h2>
    <p class="section-description">{description}</p>
  </div>
  <ol class="methodology-grid">
    {
      steps.map((step, index) => (
        <li class="methodology-step">
          <span class="methodology-step__index">{String(index + 1).padStart(2, "0")}</span>
          <span class="methodology-step__label">{step}</span>
        </li>
      ))
    }
  </ol>
</section>

<style>
  .section-block {
    padding: 36px 0;
  }

  .section-kicker {
    margin: 0 0 8px;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.74rem;
  }

  h2 {
    margin: 0;
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    line-height: 1.1;
  }

  .section-description {
    margin: 16px 0 0;
    max-width: 56rem;
    color: var(--color-muted);
    line-height: 1.8;
  }

  .methodology-grid {
    list-style: none;
    padding: 0;
    margin: 24px 0 0;
    display: grid;
    gap: 14px;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  }

  .methodology-step {
    display: grid;
    gap: 12px;
    min-height: 150px;
    padding: 22px;
    border-radius: 24px;
    background: linear-gradient(180deg, rgba(14, 24, 35, 0.92), rgba(8, 16, 25, 0.86));
    border: 1px solid var(--border-subtle);
  }

  .methodology-step__index {
    color: var(--color-accent);
    font-size: 0.84rem;
    letter-spacing: 0.14em;
  }

  .methodology-step__label {
    font-size: 1.1rem;
    line-height: 1.45;
  }
</style>
