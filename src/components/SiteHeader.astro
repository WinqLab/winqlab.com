---
import { navigationItems, siteMeta } from "../data/site";
---

<header class="site-header">
  <div class="site-header__inner">
    <a class="site-brand" href="/">
      <span class="site-brand__mark" aria-hidden="true"></span>
      <span class="site-brand__stack">
        <span class="site-brand__name">{siteMeta.name}</span>
        <span class="site-brand__meta">Research Interface</span>
      </span>
    </a>
    <div class="site-header__rail">
      <span class="site-header__badge">Static v1</span>
      <nav aria-label="Primary" class="site-nav">
        {
          navigationItems.map((item) => (
            <a href={item.href} class="site-nav__link">
              {item.label}
            </a>
          ))
        }
      </nav>
    </div>
  </div>
</header>
