---
import { researchPage } from "../data/research";
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout title={`WinqLab | ${researchPage.title}`}>
  <section class="content-hero">
    <p class="content-kicker">Research</p>
    <h1>{researchPage.title}</h1>
    <p class="content-intro">{researchPage.intro}</p>
  </section>

  <div class="content-grid">
    {
      researchPage.sections.map((section) => (
        <section class="content-panel">
          <h2>{section.title}</h2>
          <ul>
            {section.items.map((item) => <li>{item}</li>)}
          </ul>
        </section>
      ))
    }
  </div>
</SiteLayout>

<style>
  .content-hero {
    padding: 80px 0 32px;
  }

  .content-kicker {
    margin: 0 0 8px;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.74rem;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.6rem, 5vw, 4.4rem);
    line-height: 1.02;
  }

  .content-intro {
    margin: 20px 0 0;
    max-width: 50rem;
    color: var(--color-muted);
    line-height: 1.8;
  }

  .content-grid {
    display: grid;
    gap: 16px;
    padding-bottom: 48px;
  }

  .content-panel {
    padding: 24px;
    border-radius: 24px;
    border: 1px solid var(--border-subtle);
    background: var(--color-panel);
  }

  h2 {
    margin: 0 0 16px;
    font-size: 1.5rem;
  }

  ul {
    margin: 0;
    padding-left: 1.25rem;
    color: var(--color-muted);
  }

  li + li {
    margin-top: 12px;
  }

  @media (min-width: 960px) {
    .content-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
