---
import PageHero from "../components/PageHero.astro";
import { researchPage } from "../data/research";
import SiteLayout from "../layouts/SiteLayout.astro";

const researchMeta = [
  { label: "Mode", value: "Research Principles" },
  { label: "Flow", value: "Question -> Validation -> Iteration" },
  { label: "Scope", value: "Themes / Process / Future Directions" },
];
---

<SiteLayout title={`WinqLab | ${researchPage.title}`}>
  <PageHero
    kicker="Research"
    title={researchPage.title}
    intro={researchPage.intro}
    signals={["Process-first", "Peer-facing", "Methodology"]}
    meta={researchMeta}
  />

  <div class="page-grid page-grid--research">
    {
      researchPage.sections.map((section, index) => (
        <section class="page-card">
          <span class="page-card__index">{String(index + 1).padStart(2, "0")}</span>
          <h2 class="page-card__title">{section.title}</h2>
          <ul class="page-list">
            {section.items.map((item) => <li>{item}</li>)}
          </ul>
        </section>
      ))
    }
  </div>
</SiteLayout>

<style>
  @media (min-width: 960px) {
    .page-grid--research {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
