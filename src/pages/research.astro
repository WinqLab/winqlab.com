---
import PageHero from "../components/PageHero.astro";
import { researchPage } from "../data/research";
import SiteLayout from "../layouts/SiteLayout.astro";

const researchMeta = [
  { label: "模式", value: "研究原则" },
  { label: "流程", value: "问题 -> 验证 -> 迭代" },
  { label: "范围", value: "主题 / 流程 / 后续方向" },
];
---

<SiteLayout title={`WinqLab | ${researchPage.title}`}>
  <PageHero
    kicker="研究"
    title={researchPage.title}
    intro={researchPage.intro}
    signals={["过程优先", "面向同行", "方法导向"]}
    meta={researchMeta}
  />

  <div class="page-grid page-grid--research">
    {
      researchPage.sections.map((section, index) => (
        <section class="page-card">
          <span class="page-card__index">{String(index + 1).padStart(2, "0")}</span>
          <h2 class="page-card__title">{section.title}</h2>
          <ul class="page-list">
            {section.items.map((item) => <li>{item}</li>)}
          </ul>
        </section>
      ))
    }
  </div>
</SiteLayout>

<style>
  @media (min-width: 960px) {
    .page-grid--research {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
