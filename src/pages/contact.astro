---
import PageHero from "../components/PageHero.astro";
import { contactPage } from "../data/contact";
import SiteLayout from "../layouts/SiteLayout.astro";

const contactMeta = [
  { label: "Intent", value: "Research / System / Collaboration Topics" },
  { label: "Tone", value: "Low-friction / Non-sales" },
  { label: "Primary", value: "Direct Email" },
];
---

<SiteLayout title={`WinqLab | ${contactPage.title}`}>
  <PageHero
    kicker="Contact"
    title={contactPage.title}
    intro={contactPage.statement}
    signals={["Direct", "Asynchronous", "Research Topics"]}
    meta={contactMeta}
  />

  <section class="page-card page-contact-card">
    <p class="page-card__eyebrow">{contactPage.primaryLabel}</p>
    <a class="page-contact-value" href={`mailto:${contactPage.primaryValue}`}>
      {contactPage.primaryValue}
    </a>
  </section>
</SiteLayout>
