---
import PageHero from "../components/PageHero.astro";
import { notesPage } from "../data/notes";
import SiteLayout from "../layouts/SiteLayout.astro";

const notesMeta = [
  { label: "轨道", value: "方法 / 系统 / 实验" },
  { label: "状态", value: "持续整理中的研究记录" },
  { label: "形式", value: "结构化札记 / 设计 / 摘要" },
];
---

<SiteLayout title={`WinqLab | ${notesPage.title}`}>
  <PageHero
    kicker="札记"
    title={notesPage.title}
    intro={notesPage.intro}
    signals={["持续整理", "持续更新", "重视上下文"]}
    meta={notesMeta}
  />

  <div class="page-grid page-grid--notes">
    {
      notesPage.tracks.map((track, index) => (
        <article class="page-card">
          <span class="page-card__eyebrow">{String(index + 1).padStart(2, "0")}</span>
          <h2 class="page-card__title">{track}</h2>
          <p class="page-card__body">
            围绕这一轨道持续整理方法、结构和实验上下文，方便按主题查阅与回看。
          </p>
        </article>
      ))
    }
  </div>
</SiteLayout>

<style>
  .page-grid--notes > .page-card {
    min-height: 220px;
  }

  .page-grid--notes {
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }
</style>
