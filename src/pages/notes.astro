---
import { notesPage } from "../data/notes";
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout title={`WinqLab | ${notesPage.title}`}>
  <section class="content-hero">
    <p class="content-kicker">Notes</p>
    <h1>{notesPage.title}</h1>
    <p class="content-intro">{notesPage.intro}</p>
  </section>

  <div class="tracks-grid">
    {
      notesPage.tracks.map((track) => (
        <article class="track-card">
          <h2>{track}</h2>
          <p>围绕这一轨道的公开记录将逐步发布，重点呈现方法、结构和实验上下文。</p>
        </article>
      ))
    }
  </div>
</SiteLayout>

<style>
  .content-hero {
    padding: 80px 0 32px;
  }

  .content-kicker {
    margin: 0 0 8px;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.74rem;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.6rem, 5vw, 4.4rem);
    line-height: 1.02;
  }

  .content-intro {
    margin: 20px 0 0;
    max-width: 50rem;
    color: var(--color-muted);
    line-height: 1.8;
  }

  .tracks-grid {
    display: grid;
    gap: 16px;
    padding-bottom: 48px;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }

  .track-card {
    min-height: 220px;
    padding: 24px;
    border-radius: 24px;
    border: 1px solid var(--border-subtle);
    background: var(--color-panel);
  }

  h2 {
    margin: 0 0 14px;
    font-size: 1.35rem;
  }

  .track-card p {
    margin: 0;
    color: var(--color-muted);
    line-height: 1.75;
  }
</style>
