---
import PageHero from "../components/PageHero.astro";
import { notesPage } from "../data/notes";
import SiteLayout from "../layouts/SiteLayout.astro";

const notesMeta = [
  { label: "Tracks", value: "Methods / Systems / Experiments" },
  { label: "State", value: "Growing Public Archive" },
  { label: "Format", value: "Structured Notes / Design / Summaries" },
];
---

<SiteLayout title={`WinqLab | ${notesPage.title}`}>
  <PageHero
    kicker="Notes"
    title={notesPage.title}
    intro={notesPage.intro}
    signals={["Public Archive", "Gradual Release", "Context-rich"]}
    meta={notesMeta}
  />

  <div class="page-grid page-grid--notes">
    {
      notesPage.tracks.map((track, index) => (
        <article class="page-card">
          <span class="page-card__eyebrow">{String(index + 1).padStart(2, "0")}</span>
          <h2 class="page-card__title">{track}</h2>
          <p class="page-card__body">
            围绕这一轨道的公开记录将逐步发布，重点呈现方法、结构和实验上下文。
          </p>
        </article>
      ))
    }
  </div>
</SiteLayout>

<style>
  .page-grid--notes > .page-card {
    min-height: 220px;
  }

  .page-grid--notes {
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }
</style>
