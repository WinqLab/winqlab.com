---
import PageHero from "../components/PageHero.astro";
import { systemPage } from "../data/system";
import SiteLayout from "../layouts/SiteLayout.astro";

const systemMeta = [
  { label: "路径", value: "数据 -> 验证 -> 执行 -> 监控" },
  { label: "约束", value: "可审查 / 稳定性 / 可扩展" },
  { label: "输出", value: "研究系统模块" },
];
---

<SiteLayout title={`WinqLab | ${systemPage.title}`}>
  <PageHero
    kicker="系统"
    title={systemPage.title}
    intro={systemPage.intro}
    summary={systemPage.summary}
    signals={["结构总览", "关键模块", "面向执行"]}
    meta={systemMeta}
  />

  <div class="page-grid page-grid--system">
    {
      systemPage.layers.map((layer, index) => (
        <article class="page-card page-card--strong page-card--system">
          <span class="page-card__index">{String(index + 1).padStart(2, "0")}</span>
          <h2 class="page-card__title">{layer.title}</h2>
          <p class="page-card__body">{layer.description}</p>
        </article>
      ))
    }
  </div>
</SiteLayout>

<style>
  .page-grid--system {
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  }

  .page-card--system {
    min-height: 240px;
  }
</style>
