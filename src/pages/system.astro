---
import { systemPage } from "../data/system";
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout title={`WinqLab | ${systemPage.title}`}>
  <section class="content-hero">
    <p class="content-kicker">System</p>
    <h1>{systemPage.title}</h1>
    <p class="content-intro">{systemPage.intro}</p>
    <p class="content-summary">{systemPage.summary}</p>
  </section>

  <div class="layers-grid">
    {
      systemPage.layers.map((layer, index) => (
        <article class="layer-card">
          <span class="layer-card__index">{String(index + 1).padStart(2, "0")}</span>
          <h2>{layer.title}</h2>
          <p>{layer.description}</p>
        </article>
      ))
    }
  </div>
</SiteLayout>

<style>
  .content-hero {
    padding: 80px 0 32px;
  }

  .content-kicker {
    margin: 0 0 8px;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.74rem;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.6rem, 5vw, 4.4rem);
    line-height: 1.02;
  }

  .content-intro,
  .content-summary {
    max-width: 52rem;
    line-height: 1.8;
  }

  .content-intro {
    margin: 20px 0 0;
    color: var(--color-text);
  }

  .content-summary {
    margin: 12px 0 0;
    color: var(--color-muted);
  }

  .layers-grid {
    display: grid;
    gap: 16px;
    padding-bottom: 48px;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  }

  .layer-card {
    min-height: 240px;
    padding: 24px;
    border-radius: 24px;
    border: 1px solid var(--border-subtle);
    background:
      linear-gradient(180deg, rgba(61, 210, 255, 0.04), rgba(61, 210, 255, 0)),
      var(--color-panel-strong);
  }

  .layer-card__index {
    color: var(--color-accent);
    letter-spacing: 0.14em;
    font-size: 0.74rem;
  }

  h2 {
    margin: 18px 0 12px;
    font-size: 1.4rem;
  }

  .layer-card p {
    margin: 0;
    color: var(--color-muted);
    line-height: 1.75;
  }
</style>
